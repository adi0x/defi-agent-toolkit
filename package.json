{
  "name": "defi-agent-toolkit",
  "version": "0.1.0",
  "description": "Live DeFi data for AI agents on Base — 30 read-only skills across Aave, Uniswap, Aerodrome, Morpho, and Fluid",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "defi-toolkit-server": "./dist/api/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/api/server.ts",
    "start": "node dist/api/server.js",
    "test": "ts-node scripts/smoke-test.ts",
    "test:fluid": "ts-node scripts/test-fluid.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "defi", "agents", "base", "skills", "toolkit", "ai",
    "aave", "uniswap", "aerodrome", "morpho", "fluid",
    "blockchain", "ethereum", "l2", "yield", "lending"
  ],
  "author": "Fluid Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fluid-protocol/defi-agent-toolkit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "express": "^4.18.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0"
  }
}
